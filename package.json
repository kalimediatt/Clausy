    "start": "cross-env WDS_SOCKET_HOST=localhost WDS_SOCKET_PORT=3000 DANGEROUSLY_DISABLE_HOST_CHECK=true HOST=localhost PORT=3000 react-app-rewired start",
    "build": "react-app-rewired build",
    "vercel-build": "CI=false react-app-rewired build",
    "test": "react-app-rewired test",
    "eject": "react-scripts eject",
    "server": "nodemon server.js",
    "start:all": "concurrently \"npm run server\" \"npm start\"",
    "security-check": "npm audit && npm outdated",
    "migrate:chat": "node scripts/migrate_chat_conversations.js",
    "migrate:redis-to-db": "node scripts/migrate_redis_to_db.js",
    "cleanup:redis-chat": "node scripts/cleanup_redis_chat.js"
  },
  "eslintConfig": {
    "extends": [
      "react-app",
      "react-app/jest"
    ],
    "plugins": [
      "security"
    ],
    "rules": {
      "security/detect-object-injection": "warn",
      "security/detect-non-literal-regexp": "warn",
      "security/detect-unsafe-regex": "warn",
      "security/detect-buffer-noassert": "warn",
      "security/detect-eval-with-expression": "warn",
      "security/detect-no-csrf-before-method-override": "warn",
      "security/detect-possible-timing-attacks": "warn"
    }
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "devDependencies": {
    "@babel/plugin-proposal-nullish-coalescing-operator": "^7.18.6",
