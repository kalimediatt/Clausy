{
  "version": 2,
  "framework": null,
  "buildCommand": "CI=false npm run build",
  "outputDirectory": "build",
  "functions": {
    "api/index.js": {
      "maxDuration": 60,
      "includeFiles": "src/**"
    }
  },
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/index.js" }
  ]
}
